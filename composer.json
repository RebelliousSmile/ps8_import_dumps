{
    "name": "scriptami/sc_import_dumps",
    "description": "Compare SQL dumps or external databases with the current PrestaShop database and import missing data",
    "type": "prestashop-module",
    "license": "AFL-3.0",
    "authors": [
        {
            "name": "Scriptami"
        }
    ],
    "autoload": {
        "psr-4": {
            "ScImportDumps\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ScImportDumps\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "doctrine/dbal": "^3.0",
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "preferred-install": "dist"
    }
}
